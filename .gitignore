# Ignore generated dataset manifests
manifest_*.yaml

# Ignore Python cache files
__pycache__/
**/__pycache__/
*.pyc
*.pyo

# Ignore model files (too large for repo)
*.onnx
*.pth
*.gguf
**/*.onnx
**/*.pth
**/*.gguf

# Ignore generated datasets (keep only source code)
clean/
stego/
**/clean/
**/stego/
checkpoints/
test_images/

# Ignore generated models directory
models_dist/

.beads/.gitignore
.beads/README.md
.beads/config.yaml
.gemini/
.gitattributes
.grok/
**/*.log
experiments

# bv (beads viewer) local config and caches
.bv/

# Local scratch files
x.png

# Optional parity forward-pass dump (regenerated by scripts/parity_starlight_gguf.py)
fixtures/parity_logits.json

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
